--- !u!114 &1010055673
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1010055671}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9b892b765fd3a44a2a059936a98c5d4d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueScript
  ps: {fileID: 1529623387}
  levelManager: {fileID: 1529623388}
  DialogueBox: {fileID: 113217119}
  LensImage: {fileID: 675438187}
  startDi:
  - "\u0427\u0442\u043E \u044F \u0432\u0438\u0436\u0443?"
  - "\u041E, \u043D\u043E\u0432\u0438\u0447\u043E\u043A? \u041E\u0442\u043B\u0438\u0447\u043D\u043E,
    \u043A\u0430\u043A \u0440\u0430\u0437 \u0432\u043E\u0432\u0440\u0435\u043C\u044F."
  - "\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C
    \u0432 \u043D\u0430\u0448\u0443 \u043A\u043E\u043C\u043F\u0430\u043D\u0438\u044E."
  - "\u041C\u0435\u043D\u044F \u0437\u043E\u0432\u0443\u0442 \u041B\u044D\u043D\u0441.
    \u041F\u043E\u043A\u0430 \u0442\u044B \u0437\u0434\u0435\u0441\u044C - \u044F
    \u0442\u0432\u043E\u0439 \u043D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A
    \u0438, \u043F\u043E \u0441\u043E\u0432\u043C\u0435\u0441\u0442\u0438\u0442\u0435\u043B\u044C\u0441\u0442\u0432\u0443,
    \u043D\u0430\u0447\u0430\u043B\u044C\u043D\u0438\u043A."
  - "\u0421\u0435\u0439\u0447\u0430\u0441 \u0443 \u043D\u0430\u0441 \u043D\u0435
    \u0441\u0430\u043C\u044B\u0435 \u043F\u0440\u043E\u0441\u0442\u044B\u0435 \u0432\u0440\u0435\u043C\u0435\u043D\u0430..."
  - "\u041A\u0430\u043A\u043E\u0439-\u0442\u043E \u0441\u0430\u043C\u043E\u0443\u0432\u0435\u0440\u0435\u043D\u043D\u044B\u0439
    \u0445\u0430\u043A\u0435\u0440 \u0440\u0435\u0448\u0438\u043B, \u0447\u0442\u043E
    \u043E\u043D \u0443\u043C\u043D\u0435\u0435 \u043D\u0430\u0441. \u041F\u043E\u0440\u0430
    \u0434\u043E\u043A\u0430\u0437\u0430\u0442\u044C \u043E\u0431\u0440\u0430\u0442\u043D\u043E\u0435. "
  - "\u041D\u043E \u0441\u043D\u0430\u0447\u0430\u043B\u0430 - \u0442\u0435\u0431\u0435
    \u043D\u0443\u0436\u043D\u043E \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F
    \u0432 \u043E\u0441\u043D\u043E\u0432\u0430\u0445."
  - "\u041D\u0430\u0447\u043D\u0435\u043C \u0441 \u0441\u0430\u043C\u043E\u0433\u043E
    \u0432\u0430\u0436\u043D\u043E\u0433\u043E - back end."
  - "Back end \u2014 \u044D\u0442\u043E \xAB\u043D\u0435\u0432\u0438\u0434\u0438\u043C\u0430\u044F\xBB
    \u0447\u0430\u0441\u0442\u044C \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u044F.
    \u041F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C \u043D\u0435
    \u0432\u0438\u0434\u0438\u0442 \u0435\u0451 \u043D\u0430\u043F\u0440\u044F\u043C\u0443\u044E,
    \u043D\u043E \u0438\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043C \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u0442
    \u0432\u0441\u044F \u043B\u043E\u0433\u0438\u043A\u0430.  \u041A\u043E\u0433\u0434\u0430
    \u0442\u044B \u043D\u0430\u0436\u0438\u043C\u0430\u0435\u0448\u044C \u043A\u043D\u043E\u043F\u043A\u0443
    \u043D\u0430 \u0441\u0430\u0439\u0442\u0435 \u2014 \u0437\u0430\u043F\u0440\u043E\u0441
    \u0443\u0445\u043E\u0434\u0438\u0442 \u043D\u0430 \u0441\u0435\u0440\u0432\u0435\u0440.
    \u0421\u0435\u0440\u0432\u0435\u0440 \u043E\u0431\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442
    \u044D\u0442\u043E\u0442 \u0437\u0430\u043F\u0440\u043E\u0441\u2026 \u0438 \u0440\u0435\u0448\u0430\u0435\u0442,
    \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u0442\u044C \u0434\u0430\u043B\u044C\u0448\u0435."
  - "\u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440: \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u043F\u0430\u0440\u043E\u043B\u044C, \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
    \u0434\u0430\u043D\u043D\u044B\u0435 \u0438\u043B\u0438 \u0432\u0435\u0440\u043D\u0443\u0442\u044C
    \u0441\u043F\u0438\u0441\u043E\u043A \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u0439. "
  - "\u0418\u043C\u0435\u043D\u043D\u043E \u044D\u0442\u0438\u043C \u0437\u0430\u043D\u0438\u043C\u0430\u0435\u0442\u0441\u044F
    back end."
  - "\u0412 \u043D\u0430\u0448\u0435\u043C \u0441\u043B\u0443\u0447\u0430\u0435 \u0441\u0435\u0440\u0432\u0435\u0440
    \u043D\u0430\u043F\u0438\u0441\u0430\u043D \u043D\u0430 PHP. PHP - \u044D\u0442\u043E
    \u044F\u0437\u044B\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F
    \u043D\u0430 \u0441\u0435\u0440\u0432\u0435\u0440\u0435 \u0438 \u043E\u0431\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442
    \u0437\u0430\u043F\u0440\u043E\u0441\u044B. \u0422\u044B \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0448\u044C
    \u0434\u0430\u043D\u043D\u044B\u0435, PHP \u0438\u0445 \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0435\u0442,
    \u043E\u0431\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442, \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442
    \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442."
  - "\u041F\u0435\u0440\u0435\u0434 \u0442\u043E\u0431\u043E\u0439 \u043F\u0440\u0438\u043C\u0435\u0440
    \u0441\u0435\u0440\u0432\u0435\u0440\u043D\u043E\u0433\u043E \u043A\u043E\u0434\u0430.
    \u041D\u0430 \u043F\u0435\u0440\u0432\u044B\u0439 \u0432\u0437\u0433\u043B\u044F\u0434
    \u043E\u043D \u043C\u043E\u0436\u0435\u0442 \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C\u0441\u044F
    \u043D\u0435\u043F\u043E\u043D\u044F\u0442\u043D\u044B\u043C, \u043D\u043E \u043D\u0430
    \u0441\u0430\u043C\u043E\u043C \u0434\u0435\u043B\u0435 \u0437\u0434\u0435\u0441\u044C
    \u0432\u0441\u0435\u0433\u043E \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0431\u0430\u0437\u043E\u0432\u044B\u0445 \u0432\u0435\u0449\u0435\u0439: \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435,
    \u0432\u0445\u043E\u0434\u043D\u044B\u0435 \u0434\u0430\u043D\u043D\u044B\u0435,
    \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u0438 \u0432\u044B\u0432\u043E\u0434.
    \u0415\u0441\u043B\u0438 \u0442\u044B \u0440\u0430\u0437\u0431\u0435\u0440\u0451\u0448\u044C\u0441\u044F
    \u0432 \u044D\u0442\u043E\u043C \u043F\u0440\u0438\u043C\u0435\u0440\u0435 \u2014
    \u0442\u044B \u0443\u0436\u0435 \u043F\u043E\u0439\u043C\u0451\u0448\u044C \u043E\u0441\u043D\u043E\u0432\u0443
    \u0440\u0430\u0431\u043E\u0442\u044B \u043B\u044E\u0431\u043E\u0433\u043E back
    end."
  - //CODE HERE//
  - "\u041D\u0430\u0447\u043D\u0435\u043C \u0441 \u043F\u0435\u0440\u0432\u043E\u0439
    \u0441\u0442\u0440\u043E\u043A\u0438: $name = $_POST['name'];. \u0421\u0438\u043C\u0432\u043E\u043B
    $ \u0432 PHP \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0443\u044E
    \u2014 \u0442\u043E \u0435\u0441\u0442\u044C \u043C\u0435\u0441\u0442\u043E,
    \u0433\u0434\u0435 \u0445\u0440\u0430\u043D\u0438\u0442\u0441\u044F \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435.
    \u0412 \u0434\u0430\u043D\u043D\u043E\u043C \u0441\u043B\u0443\u0447\u0430\u0435
    \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F $name \u0431\u0443\u0434\u0435\u0442
    \u0445\u0440\u0430\u043D\u0438\u0442\u044C \u0438\u043C\u044F \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044F,
    \u043A\u043E\u0442\u043E\u0440\u043E\u0435 \u043C\u044B \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u043C
    \u0441 \u0441\u0435\u0440\u0432\u0435\u0440\u0430. "
  - "$_POST \u2014 \u044D\u0442\u043E \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u044C\u043D\u044B\u0439
    \u043C\u0430\u0441\u0441\u0438\u0432, \u0432 \u043A\u043E\u0442\u043E\u0440\u044B\u0439
    \u0441\u0435\u0440\u0432\u0435\u0440 \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0438\u0447\u0435\u0441\u043A\u0438
    \u043F\u043E\u043C\u0435\u0449\u0430\u0435\u0442 \u0434\u0430\u043D\u043D\u044B\u0435,
    \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u043D\u044B\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u0435\u043C
    \u0447\u0435\u0440\u0435\u0437 \u0444\u043E\u0440\u043C\u0443. \u0417\u0430\u043F\u0438\u0441\u044C
    ['name'] \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043C\u044B \u0431\u0435\u0440\u0451\u043C \u043A\u043E\u043D\u043A\u0440\u0435\u0442\u043D\u043E\u0435
    \u043F\u043E\u043B\u0435 \u0441 \u0438\u043C\u0435\u043D\u0435\u043C name. "
  - "\u041A\u0440\u043E\u043C\u0435 $_POST \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442
    \u0435\u0449\u0451 $_GET. \u041E\u043D \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442
    \u043F\u043E\u0445\u043E\u0436\u0435, \u043D\u043E \u043F\u0435\u0440\u0435\u0434\u0430\u0435\u0442
    \u0434\u0430\u043D\u043D\u044B\u0435 \u0447\u0435\u0440\u0435\u0437 URL, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440:
    site.com?name=Alex. \u0412 \u043E\u0442\u043B\u0438\u0447\u0438\u0435 \u043E\u0442
    \u043D\u0435\u0433\u043E, $_POST \u043F\u0435\u0440\u0435\u0434\u0430\u0451\u0442
    \u0434\u0430\u043D\u043D\u044B\u0435 \u0441\u043A\u0440\u044B\u0442\u043E, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
    \u0447\u0430\u0449\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0434\u043B\u044F \u0444\u043E\u0440\u043C \u0438 \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u0430\u0446\u0438\u0438. "
  - "\u0422\u0435\u043F\u0435\u0440\u044C \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438\u043C
    \u043D\u0430 \u0443\u0441\u043B\u043E\u0432\u0438\u0435: if ($name == \"\").
    \u041A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044F if \u043F\u043E\u0437\u0432\u043E\u043B\u044F\u0435\u0442
    \u0441\u0435\u0440\u0432\u0435\u0440\u0443 \u043F\u0440\u0438\u043D\u0438\u043C\u0430\u0442\u044C
    \u0440\u0435\u0448\u0435\u043D\u0438\u044F. \u0417\u0434\u0435\u0441\u044C \u043C\u044B
    \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u043C: \u043F\u0443\u0441\u0442\u043E\u0435
    \u043B\u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439.
    \u0415\u0441\u043B\u0438 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C
    \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0432\u0432\u0451\u043B \u2014
    \u0443\u0441\u043B\u043E\u0432\u0438\u0435 \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u0442\u0441\u044F. "
  - "\u0415\u0441\u043B\u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u0435 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F
    \u2014 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F \u043A\u043E\u0434
    \u0432\u043D\u0443\u0442\u0440\u0438 \u0431\u043B\u043E\u043A\u0430. \u0412 \u043D\u0430\u0448\u0435\u043C
    \u0441\u043B\u0443\u0447\u0430\u0435 \u0441\u0435\u0440\u0432\u0435\u0440 \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442:
    \"\u0418\u043C\u044F \u043D\u0435 \u0443\u043A\u0430\u0437\u0430\u043D\u043E\".
    \u0414\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u043A\u043E\u043C\u0430\u043D\u0434\u0430 echo \u2014 \u043E\u043D\u0430 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442
    \u0442\u0435\u043A\u0441\u0442 \u043E\u0431\u0440\u0430\u0442\u043D\u043E \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044E. "
  - "\u0415\u0441\u043B\u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u0435 \u043D\u0435
    \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F, \u0441\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u0435\u0442
    \u0431\u043B\u043E\u043A else \u2014 \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u043D\u044B\u0439
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442. \u0422\u043E\u0433\u0434\u0430 \u0441\u0435\u0440\u0432\u0435\u0440
    \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442 \u0434\u0440\u0443\u0433\u0443\u044E
    \u043A\u043E\u043C\u0430\u043D\u0434\u0443 \u0438 \u0432\u044B\u0432\u043E\u0434\u0438\u0442
    \u043F\u0440\u0438\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 \u0441 \u0438\u043C\u0435\u043D\u0435\u043C
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044F. "
  - "\u0421\u0442\u0440\u043E\u043A\u0430 echo \"\u041F\u0440\u0438\u0432\u0435\u0442,
    \" . $name; \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u044F\u0435\u0442 \u0442\u0435\u043A\u0441\u0442
    \u0438 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439.
    \u0422\u043E\u0447\u043A\u0430 \u0432 PHP \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u0442\u0441\u044F
    \u0434\u043B\u044F \u0441\u043A\u043B\u0435\u0438\u0432\u0430\u043D\u0438\u044F
    \u0441\u0442\u0440\u043E\u043A. \u0412 \u0438\u0442\u043E\u0433\u0435 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C
    \u0443\u0432\u0438\u0434\u0438\u0442, \u043D\u0430\u043F\u0440\u0438\u043C\u0435\u0440:
    \u041F\u0440\u0438\u0432\u0435\u0442, Alex. "
  - "\u0412\u0430\u0436\u043D\u043E \u043F\u043E\u043D\u0438\u043C\u0430\u0442\u044C:
    \u0441\u0435\u0440\u0432\u0435\u0440 \u043D\u0435 \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u0435\u0442
    \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441. \u041E\u043D \u043F\u0440\u043E\u0441\u0442\u043E
    \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442 \u0434\u0430\u043D\u043D\u044B\u0435.
    \u0423\u0436\u0435 \u043A\u043B\u0438\u0435\u043D\u0442\u0441\u043A\u0430\u044F
    \u0447\u0430\u0441\u0442\u044C \u0440\u0435\u0448\u0430\u0435\u0442, \u043A\u0430\u043A
    \u0438\u043C\u0435\u043D\u043D\u043E \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u044D\u0442\u043E\u0442 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044E. "
  - "\u0422\u0435\u043F\u0435\u0440\u044C \u043D\u0435\u043C\u043D\u043E\u0433\u043E
    \u0433\u043B\u0443\u0431\u0436\u0435. $_POST \u2014 \u044D\u0442\u043E \u043C\u0430\u0441\u0441\u0438\u0432.
    \u041C\u0430\u0441\u0441\u0438\u0432 \u2014 \u044D\u0442\u043E \u0441\u0442\u0440\u0443\u043A\u0442\u0443\u0440\u0430
    \u0434\u0430\u043D\u043D\u044B\u0445, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u0445\u0440\u0430\u043D\u0438\u0442 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439. \u0412 PHP \u043C\u0430\u0441\u0441\u0438\u0432\u044B
    \u0447\u0430\u0441\u0442\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442
    \u043A\u0430\u043A \u0441\u043B\u043E\u0432\u0430\u0440\u0438: \u0443 \u043A\u0430\u0436\u0434\u043E\u0433\u043E
    \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F \u0435\u0441\u0442\u044C \u043A\u043B\u044E\u0447. "
  - "\u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u043C\u0430\u0441\u0441\u0438\u0432
    \u043C\u043E\u0436\u0435\u0442 \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u0442\u044C
    \u0442\u0430\u043A: [\"name\" => \"Alex\", \"age\" => 20]. \u0427\u0442\u043E\u0431\u044B
    \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0438\u043C\u044F \u2014 \u043C\u044B
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0435\u043C \u043A\u043B\u044E\u0447
    'name', \u0430 \u0447\u0442\u043E\u0431\u044B \u0432\u043E\u0437\u0440\u0430\u0441\u0442
    \u2014 'age'. "
  - "\u041C\u0430\u0441\u0441\u0438\u0432\u044B \u043C\u043E\u0436\u043D\u043E \u0438\u0437\u043C\u0435\u043D\u044F\u0442\u044C.
    \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0434\u043E\u0431\u0430\u0432\u043B\u044F\u0442\u044C
    \u043D\u043E\u0432\u044B\u0435 \u044D\u043B\u0435\u043C\u0435\u043D\u0442\u044B.
    \u042D\u0442\u043E \u0447\u0430\u0441\u0442\u043E \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442
    push \u2014 \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435
    \u0432 \u0441\u043F\u0438\u0441\u043E\u043A. \u0412 PHP \u0434\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u0435\u0441\u0442\u044C \u0444\u0443\u043D\u043A\u0446\u0438\u044F array_push,
    \u043D\u043E \u0447\u0430\u0449\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u044E\u0442
    \u043A\u043E\u0440\u043E\u0442\u043A\u0443\u044E \u0437\u0430\u043F\u0438\u0441\u044C:
    $users[] = \"Alex\". "
  - "\u0415\u0441\u043B\u0438 \u043E\u0431\u044A\u0435\u0434\u0438\u043D\u0438\u0442\u044C
    \u0432\u0441\u0451, \u0447\u0442\u043E \u0442\u044B \u0443\u0437\u043D\u0430\u043B:
    \u0441\u0435\u0440\u0432\u0435\u0440 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442
    \u0434\u0430\u043D\u043D\u044B\u0435 \u043E\u0442 \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044F,
    \u0441\u043E\u0445\u0440\u0430\u043D\u044F\u0435\u0442 \u0438\u0445 \u0432 \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u044B\u0435,
    \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0435\u0442 \u0443\u0441\u043B\u043E\u0432\u0438\u044F
    \u0438 \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442 \u043E\u0442\u0432\u0435\u0442.
    \u042D\u0442\u043E \u0431\u0430\u0437\u043E\u0432\u044B\u0439 \u0446\u0438\u043A\u043B
    \u0440\u0430\u0431\u043E\u0442\u044B \u043B\u044E\u0431\u043E\u0433\u043E back
    end. "
  - "\u0418\u043C\u0435\u043D\u043D\u043E \u0442\u0430\u043A \u0440\u0430\u0431\u043E\u0442\u0430\u044E\u0442
    \u0444\u043E\u0440\u043C\u044B, \u043B\u043E\u0433\u0438\u043D\u044B, \u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u044F
    \u0438 \u043F\u0440\u0430\u043A\u0442\u0438\u0447\u0435\u0441\u043A\u0438 \u0432\u0441\u0435
    \u0441\u0435\u0440\u0432\u0435\u0440\u043D\u044B\u0435 \u0441\u0438\u0441\u0442\u0435\u043C\u044B.
    \u0421\u0435\u0439\u0447\u0430\u0441 \u0442\u044B \u0438\u0437\u0443\u0447\u0430\u0435\u0448\u044C
    \u0444\u0443\u043D\u0434\u0430\u043C\u0435\u043D\u0442, \u043D\u0430 \u043A\u043E\u0442\u043E\u0440\u043E\u043C
    \u0441\u0442\u0440\u043E\u0438\u0442\u0441\u044F \u0432\u0441\u044F \u043B\u043E\u0433\u0438\u043A\u0430
    \u043F\u0440\u0438\u043B\u043E\u0436\u0435\u043D\u0438\u0439. "
  - "\u0422\u0435\u043F\u0435\u0440\u044C \u043E\u0442 \u0442\u0435\u043E\u0440\u0438\u0438
    \u043F\u0435\u0440\u0435\u0439\u0434\u0435\u043C \u043A \u043F\u0440\u0430\u043A\u0442\u0438\u043A\u0435.
    \u041D\u0430 \u043F\u043E\u043B\u0435 \u043D\u0430\u0439\u0434\u0438 \u0431\u043B\u043E\u043A
    \u0441 \u0431\u0443\u043A\u0432\u0430\u043C\u0438 \"BE\" \u043D\u0430 \u043D\u0435\u043C,
    \u044D\u0442\u043E \u0438 \u0435\u0441\u0442\u044C \u0442\u0432\u043E\u0439 Back-End
    \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A. \u041D\u0430\u0436\u043C\u0438
    \u043D\u0430 \u043D\u0435\u0433\u043E, \u0430 \u043F\u043E\u0442\u043E\u043C
    \u043D\u0430\u0436\u043C\u0438 \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
    \u043D\u0430\u0441\u0442\u0440\u043E\u0438\u0442\u044C \u0438 \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0439
    \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C \u0441\u0432\u043E\u0439 \u043A\u043E\u0434."
  - "\u0421\u0435\u0439\u0447\u0430\u0441 \u0442\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u043E
    \u0441\u0430\u043C\u043E\u0441\u0442\u043E\u044F\u0442\u0435\u043B\u044C\u043D\u043E
    \u043D\u0430\u043F\u0438\u0441\u0430\u0442\u044C \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439
    \u043A\u0443\u0441\u043E\u043A \u0441\u0435\u0440\u0432\u0435\u0440\u043D\u043E\u0439
    \u043B\u043E\u0433\u0438\u043A\u0438. \u041F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u044C,
    \u0447\u0442\u043E \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C
    \u043E\u0442\u043F\u0440\u0430\u0432\u043B\u044F\u0435\u0442 \u0441\u0432\u043E\u0451
    \u0438\u043C\u044F \u043D\u0430 \u0441\u0435\u0440\u0432\u0435\u0440, \u0438
    \u0442\u044B \u0434\u043E\u043B\u0436\u0435\u043D \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u044D\u0442\u043E\u0442 \u0437\u0430\u043F\u0440\u043E\u0441. \u0423 \u0442\u0435\u0431\u044F
    \u0443\u0436\u0435 \u0435\u0441\u0442\u044C \u043F\u0435\u0440\u0435\u043C\u0435\u043D\u043D\u0430\u044F
    $name, \u0432 \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0445\u0440\u0430\u043D\u0438\u0442\u0441\u044F
    \u0432\u0432\u0435\u0434\u0451\u043D\u043D\u043E\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0435."
  - "\u0422\u0432\u043E\u044F \u0437\u0430\u0434\u0430\u0447\u0430 \u2014 \u0434\u043E\u0431\u0430\u0432\u0438\u0442\u044C
    \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0443: \u0435\u0441\u043B\u0438 \u0438\u043C\u044F
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044F \u0440\u0430\u0432\u043D\u043E
    \"admin\", \u0441\u0435\u0440\u0432\u0435\u0440 \u0434\u043E\u043B\u0436\u0435\u043D
    \u0432\u044B\u0432\u0435\u0441\u0442\u0438 \u0441\u043E\u043E\u0431\u0449\u0435\u043D\u0438\u0435
    \"\u0414\u043E\u0431\u0440\u043E \u043F\u043E\u0436\u0430\u043B\u043E\u0432\u0430\u0442\u044C,
    \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\".
    \u042D\u0442\u043E \u043E\u0437\u043D\u0430\u0447\u0430\u0435\u0442, \u0447\u0442\u043E
    \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C \u043F\u043E\u043B\u0443\u0447\u0438\u043B
    \u043F\u043E\u043B\u043D\u044B\u0439 \u0434\u043E\u0441\u0442\u0443\u043F. \u0412\u043E
    \u0432\u0441\u0435\u0445 \u043E\u0441\u0442\u0430\u043B\u044C\u043D\u044B\u0445
    \u0441\u043B\u0443\u0447\u0430\u044F\u0445 \u043D\u0443\u0436\u043D\u043E \u0432\u044B\u0432\u0435\u0441\u0442\u0438
    \"\u0414\u043E\u0441\u0442\u0443\u043F \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D\"."
  - "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439 \u043A\u043E\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u044E
    if \u0434\u043B\u044F \u043F\u0440\u043E\u0432\u0435\u0440\u043A\u0438 \u0443\u0441\u043B\u043E\u0432\u0438\u044F
    \u0438 \u043D\u0435 \u0437\u0430\u0431\u0443\u0434\u044C \u043F\u0440\u043E else,
    \u0447\u0442\u043E\u0431\u044B \u043E\u0431\u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
    \u0430\u043B\u044C\u0442\u0435\u0440\u043D\u0430\u0442\u0438\u0432\u043D\u044B\u0439
    \u0432\u0430\u0440\u0438\u0430\u043D\u0442. \u0414\u043B\u044F \u0432\u044B\u0432\u043E\u0434\u0430
    \u043E\u0442\u0432\u0435\u0442\u0430 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439
    \u043A\u043E\u043C\u0430\u043D\u0434\u0443 echo. \u0422\u0430\u043A\u0436\u0435
    \u043F\u043E\u043C\u043D\u0438, \u0447\u0442\u043E \u0441\u0442\u0440\u043E\u043A\u0438
    \u0432 PHP \u043F\u0438\u0448\u0443\u0442\u0441\u044F \u0432 \u043A\u0430\u0432\u044B\u0447\u043A\u0430\u0445,
    \u0430 \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u0439
    \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0435\u0442\u0441\u044F \u0441 \u043F\u043E\u043C\u043E\u0449\u044C\u044E
    \u043E\u043F\u0435\u0440\u0430\u0442\u043E\u0440\u0430 ==."
  lose:
  - "\u0414\u0430 \u0443\u0436..."
  - "\u041D\u0435\u043C\u043D\u043E\u0433\u043E \u043D\u0435 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C."
  - "\u042F \u043F\u043E\u043D\u0438\u043C\u0430\u044E, \u0447\u0442\u043E \u044D\u0442\u043E
    \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C \u043D\u0435\u043C\u043D\u043E\u0433\u043E
    \u043E\u0431\u0438\u0434\u043D\u043E, \u043D\u043E \u043D\u0435 \u0432\u0441\u0435
    \u0432\u0441\u0435\u0433\u0434\u0430 \u043F\u043E\u043B\u0443\u0447\u0430\u0435\u0442\u0441\u044F
    \u0441 \u043F\u0435\u0440\u0432\u043E\u0433\u043E \u0440\u0430\u0437\u0430. \u0413\u043B\u0430\u0432\u043D\u043E\u0435
    \u043D\u0435 \u0441\u0434\u0430\u0432\u0430\u0442\u044C\u0441\u044F \u0438 \u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
    \u0434\u0430\u043B\u044C\u0448\u0435!"
  - "\u0414\u0430\u0432\u0430\u0439 \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0435\u043C
    \u0435\u0449\u0435 \u0440\u0430\u0437!"
  win:
  - "\u0410 \u0437\u043D\u0430\u0435\u0448\u044C \u0447\u0442\u043E?"
  - "\u042F \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432\u043F\u0435\u0447\u0430\u0442\u043B\u0435\u043D!"
  - "\u0422\u044B \u0431\u044B\u0441\u0442\u0440\u043E \u0441\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0435\u0448\u044C,
    \u043D\u043E\u0432\u0438\u0447\u043E\u043A!"
  - "\u041F\u043E\u0439\u0434\u0435\u043C \u0434\u0430\u043B\u044C\u0448\u0435, \u044F
    \u0440\u0430\u0441\u0441\u043A\u0430\u0436\u0443 \u0442\u0435\u0431\u0435 \u0438
    \u043F\u0440\u043E \u0434\u0440\u0443\u0433\u0438\u0435 \u0432\u0435\u0449\u0438,
    \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0435 \u0441 \u043D\u0430\u0448\u0435\u0439
    \u0440\u0430\u0431\u043E\u0442\u043E\u0439."
  StartDialogueLensSprite: 00000000010000000600000001000000020000000700000006000000000000000600000006000000060000000600000006000000000000000400000006000000020000000200000002000000060000000600000007000000070000000200000007000000060000000200000005000000010000000600000007000000
